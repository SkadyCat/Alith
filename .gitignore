# Dependencies
node_modules/

# Excluded directories
# application/ — now tracked in repo

# Sensitive keys / credentials
docs/key/

# Local config (use global_config_temp.json as template)
docs/global_config.json

# Application-specific docs (separate repo concern)
docs/application_doc/
# Exception: MagicWorld design data must be tracked
!docs/application_doc/
!docs/application_doc/magicworld/
!docs/application_doc/magicworld/**

# Runtime data
data/

# Tools runtimes (large binaries)
tools/pwsh7/

# Docs history (session logs, auto-generated)
docs/history/

# Environment files
.env
*.env

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Python virtual environment
tools/venv/

# Embedded Python (large binary)
tools/python/
