+/* ===== RESPONSIVE / ADAPTIVE LAYOUT ===== */

+

+/* When agent panel is open: auto-collapse editor pane on screens ≤ 1440px

+   so the remaining doc area is fully available for the preview */

+@media (max-width: 1440px) {

+  body.agent-panel-open .editor-pane {

+    display: none;

+  }

+  body.agent-panel-open .split-divider {

+    display: none;

+  }

+  /* Preview pane takes all available width */

+  body.agent-panel-open .preview-pane {

+    flex: 1;

+    min-width: 0;

+  }

+}

+

+/* Narrow desktop (901px – 1050px):

+   Keep agent panel from eating >55% of viewport */

+@media (max-width: 1050px) {

+  .agent-panel {

+    width: min(480px, 55vw);

+    max-width: 55vw;

+  }

+  .session-panel.open {

+    transform: translateX(calc(-1 * min(480px, 55vw)));

+  }

+  body.agent-panel-open .main-layout {

+    padding-right: calc(min(480px, 55vw) + 156px);

+  }

+}

+

+/* Tablet / small screen (≤ 768px):

+   Agent panel becomes a full-width overlay; doc panes stack vertically */

+@media (max-width: 768px) {

+  /* Agent/PyAgent panel: full-width overlay, no content push */

+  .agent-panel {

+    width: 100vw;

+    max-width: 100vw;

+  }

+  body.agent-panel-open .main-layout {

+    padding-right: 0;

+  }

+  /* Session panel: hide when agent is open on small screens */

+  .session-panel {

+    display: none;

+  }

+

+  /* Document editor + preview: stack vertically */

+  .doc-area {

+    flex-direction: column;

+  }

+  .editor-pane {

+    border-right: none;

+    border-bottom: 1px solid var(--border);

+    min-height: 200px;

+    flex: 1 1 50%;

+  }

+  .split-divider {

+    width: 100%;

+    height: 4px;

+    cursor: row-resize;

+  }

+  .preview-pane {

+    min-height: 150px;

